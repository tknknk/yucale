# Timezone
TZ=Asia/Tokyo

# Database
DB_HOST=db
DB_PORT=5432
DB_NAME=ren_cale
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Application
ADMIN_EMAIL=admin@example.com
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx

# Discord notifications per event (default: true). Set to false to suppress.
# DISCORD_NOTIFY_REQUEST=true    # ロール変更リクエスト時
# DISCORD_NOTIFY_APPROVAL=true   # リクエスト承認時
# DISCORD_NOTIFY_REJECTION=true  # リクエスト却下時

# CORS allowed origins (comma-separated). Defaults to http://localhost:3000 for
# local dev; override in production with the public (CloudFront) origin.
# CORS_ALLOWED_ORIGINS=http://localhost:3000

# Survey Defaults
DEFAULT_BELONGING_LIST=S,A,T,B
DEFAULT_RESPONSE_OPTIONS=出席,欠席,未定
DEFAULT_ATTENDING_OPTIONS=出席
# チェックボックスのデフォルトラベル（空欄可）
DEFAULT_CHECKBOX_LABEL=

# ICS
ICS_FILE_PATH=/app/data
ICS_FILE_NAME=calendar.ics

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080/api
NEXT_PUBLIC_ICS_FILENAME=calendar.ics

# Schedule Default Time (HH:mm, 15-minute intervals)
# If not set, defaults to current time rounded to nearest hour
NEXT_PUBLIC_DEFAULT_START_TIME=09:00
NEXT_PUBLIC_DEFAULT_END_TIME=10:00
