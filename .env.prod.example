# =============================================================================
# Environment Variables - Production (AWS EC2)
# Yucale Service
# =============================================================================
# Copy this file to .env and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# Database Settings
# -----------------------------------------------------------------------------
DB_NAME=yucale
DB_USERNAME=yucale_admin
DB_PASSWORD=your-secure-password-here

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
ADMIN_EMAIL=admin@example.com
DISCORD_WEBHOOK_URL=

# CORS allowed origins (comma-separated). MUST be set to the public origin the
# browser uses, i.e. the CloudFront URL. Without this, API POSTs are rejected
# with 403 (Invalid CORS request).
CORS_ALLOWED_ORIGINS=https://your-distribution.cloudfront.net

# Public site URL used for links in Discord notifications (e.g. the admin
# "Review" link). Set to the CloudFront URL; if unset, links fall back to
# http://localhost:3000.
FRONTEND_URL=https://your-distribution.cloudfront.net

# Response options (comma-separated)
DEFAULT_BELONGING_LIST=S,A,T,B
DEFAULT_RESPONSE_OPTIONS=出席,欠席,未定
DEFAULT_ATTENDING_OPTIONS=出席

# -----------------------------------------------------------------------------
# Frontend Settings
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_ICS_FILENAME=calendar.ics
NEXT_PUBLIC_DEFAULT_START_TIME=18:00
NEXT_PUBLIC_DEFAULT_END_TIME=21:00

# -----------------------------------------------------------------------------
# AWS Settings
# -----------------------------------------------------------------------------
AWS_REGION=ap-northeast-1
S3_BUCKET_NAME=

# -----------------------------------------------------------------------------
# Timezone
# -----------------------------------------------------------------------------
TZ=Asia/Tokyo
