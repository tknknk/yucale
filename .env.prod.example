# =============================================================================
# Environment Variables - Production (AWS EC2)
# Yucale Service
# =============================================================================
# Copy this file to .env and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# Database Settings
# -----------------------------------------------------------------------------
DB_NAME=yucale
DB_USERNAME=yucale_admin
DB_PASSWORD=your-secure-password-here

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
ADMIN_EMAIL=admin@example.com
DISCORD_WEBHOOK_URL=

# Discord notifications per event (default: true). Set to false to suppress.
# DISCORD_NOTIFY_REQUEST=true    # ロール変更リクエスト時
# DISCORD_NOTIFY_APPROVAL=true   # リクエスト承認時
# DISCORD_NOTIFY_REJECTION=true  # リクエスト却下時

# CORS allowed origins (comma-separated). MUST be set to the public origin the
# browser uses, i.e. the CloudFront URL. Without this, API POSTs are rejected
# with 403 (Invalid CORS request).
CORS_ALLOWED_ORIGINS=https://your-distribution.cloudfront.net

# Public site URL used for links in Discord notifications (e.g. the admin
# "Review" link). Set to the CloudFront URL; if unset, links fall back to
# http://localhost:3000.
FRONTEND_URL=https://your-distribution.cloudfront.net

# Mark session + CSRF cookies with the Secure attribute (browsers only send them
# over HTTPS). Keep true in production; the docker-compose.prod.yml default is
# already true, so you normally do not need to set this.
APP_COOKIE_SECURE=true

# Number of trusted reverse-proxy hops in front of the backend, used to derive
# the real client IP from X-Forwarded-For for rate limiting. Production runs
# behind CloudFront + nginx = 2. Lowering this lets clients spoof their IP and
# bypass per-IP rate limits; the compose default is already 2.
APP_TRUSTED_PROXY_COUNT=2

# Response options (comma-separated)
DEFAULT_BELONGING_LIST=S,A,T,B
DEFAULT_RESPONSE_OPTIONS=出席,欠席,未定
DEFAULT_ATTENDING_OPTIONS=出席
# チェックボックスのデフォルトラベル（空欄可）
DEFAULT_CHECKBOX_LABEL=

# Optional tuning (defaults shown; uncomment to override). These have sane
# defaults in application.yml and are not required.
#   LOGIN_MAX_FAILED_ATTEMPTS: consecutive login failures before lockout
#LOGIN_MAX_FAILED_ATTEMPTS=5
#   LOGIN_LOCK_DURATION_MINUTES: lockout duration in minutes
#LOGIN_LOCK_DURATION_MINUTES=15
#   ICS_OUTPUT_PATH: file path the backend writes the generated calendar.ics to
#ICS_OUTPUT_PATH=./calendar.ics

# -----------------------------------------------------------------------------
# Frontend Settings
# -----------------------------------------------------------------------------
# NOTE: NEXT_PUBLIC_* values are baked into the frontend image at BUILD time by
# .github/workflows/build-and-push.yml, NOT read from this .env at runtime.
# docker-compose.prod.yml pulls the prebuilt image (ghcr.io/.../frontend), so
# setting these here has NO effect on production. To change them, edit the build
# args in the workflow. Listed below only for reference (kept in sync with the
# workflow defaults):
#   NEXT_PUBLIC_API_URL=/api
#   NEXT_PUBLIC_ICS_FILENAME=calendar.ics
#   NEXT_PUBLIC_DEFAULT_START_TIME=18:00
#   NEXT_PUBLIC_DEFAULT_END_TIME=21:00

# -----------------------------------------------------------------------------
# AWS Settings
# -----------------------------------------------------------------------------
# NOTE: Both vars are forward-looking plumbing for the planned "serve ICS from
# S3" feature and are NOT read by the backend application today. The infra is
# already provisioned (Terraform creates the ICS bucket, grants the EC2 role
# s3:GetObject/PutObject/DeleteObject, and wires an S3 CloudFront origin — see
# aws/terraform/s3.tf and ec2.tf). When the backend gains S3-upload code, it
# will need the bucket name here and the AWS SDK will read AWS_REGION from the
# environment. On AWS, user_data.sh overwrites these from Terraform outputs, so
# the values below mainly matter for non-Terraform/manual runs.
#
# Region the backend's future AWS SDK calls target.
AWS_REGION=ap-northeast-1
# Name of the ICS S3 bucket (leave blank; Terraform injects the real name).
S3_BUCKET_NAME=

# -----------------------------------------------------------------------------
# Timezone
# -----------------------------------------------------------------------------
TZ=Asia/Tokyo
